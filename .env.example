# Copy this file to .env and fill in your values

# Google Gemini API key (free tier): https://aistudio.google.com/apikey
# IMPORTANT: Key must start with "AIza" (from AI Studio, not Google Cloud Console)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: models to try in order if one hits quota limits (all free tier)
GEMINI_MODELS=gemini-2.0-flash-lite,gemini-1.5-flash,gemini-2.0-flash

# Slack incoming webhook URL: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Google Sheets ID (from the spreadsheet URL)
# Example URL: https://docs.google.com/spreadsheets/d/ABC123xyz/edit
# The ID is: ABC123xyz
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Your name for proposal signatures
MY_NAME=Maria

# Optional settings (defaults shown)
POLL_INTERVAL_MINUTES=30
SCORE_THRESHOLD=6
MIN_BUDGET_HOURLY=15
MIN_BUDGET_FIXED=100
